carrusel reflexivo {

    meta {
        version: "1.0"
        tema: "Origen"
        tono: "poético+conceptual"
    }

    slide 1 {
        img: "assets/madonna_hibrida/04.jpg"
        text: "El origen no fue un acto…"
    }

    slide 2 {
        text: "…fue una pregunta."
    }

    slide 3 {
        text: "¿Qué nace cuando lo sagrado y lo profano\nrespiran al mismo tiempo?"
    }

    styles {
        font: "Bodoni"
        motion: "fade"
        color: "#FFFFFF"
    }

}
